<mah:MetroWindow x:Class="TelegramAutoDownload.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Application logs"
        Height="560" Width="800"
        MinHeight="400" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,0,0,8">
            Log files are stored under your AppData folder (see Open folder). Large files show the last portion only.
        </TextBlock>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Top" Text="Log files" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ListBox x:Name="lstLogs" SelectionChanged="LstLogs_OnSelectionChanged"/>
        </DockPanel>

        <GroupBox Grid.Row="2" Header="Content" Padding="6">
            <TextBox x:Name="tbContent" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"/>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Right">
            <Button Content="Refresh" Width="88" Height="30" Margin="0,0,8,0" Click="BtnRefresh_OnClick"/>
            <Button Content="Open folder" Width="100" Height="30" Margin="0,0,8,0" Click="BtnOpenFolder_OnClick"/>
            <Button Content="Delete selected" Width="110" Height="30" Margin="0,0,8,0" Click="BtnDelete_OnClick"/>
            <Button Content="Close" Width="72" Height="30" IsCancel="True" Click="BtnClose_OnClick"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
