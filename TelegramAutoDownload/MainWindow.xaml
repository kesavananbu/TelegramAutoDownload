<mah:MetroWindow x:Class="TelegramAutoDownload.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:conv="clr-namespace:TelegramAutoDownload.Converters"
       mc:Ignorable="d"
       Title="Telegram Auto Download"
       AutomationProperties.AutomationId="TelegramMainWindow"
       Height="800" Width="1440"
       MinWidth="640" MinHeight="400"
       WindowStartupLocation="CenterScreen">

    <mah:MetroWindow.Resources>
        <Storyboard x:Key="BlinkVersion" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="btnAppVersion"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.6" Value="0.2"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.2" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="BlinkError" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="btnErrorLog"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="0.25"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.0" Value="1.0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <conv:StringNotEmptyConverter     x:Key="StringNotEmpty"/>
        <conv:CollectionNotEmptyConverter x:Key="CollectionNotEmpty"/>

        <!-- Compact indicator button for Filter column: amber when patterns are set -->
        <Style x:Key="FilterBtnStyle" TargetType="Button">
            <Setter Property="Width"         Value="26"/>
            <Setter Property="Height"        Value="22"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="Padding"       Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="{DynamicResource MahApps.Brushes.Gray3}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource MahApps.Brushes.Gray7}"/>
            <Setter Property="ToolTip"       Value="Open filter editor"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IgnoreFileByRegex, Converter={StaticResource CollectionNotEmpty}}"
                             Value="True">
                    <Setter Property="Background"  Value="#FF9800"/>
                    <Setter Property="Foreground"  Value="White"/>
                    <Setter Property="BorderBrush" Value="#E65100"/>
                    <Setter Property="FontWeight"  Value="Bold"/>
                    <Setter Property="ToolTip"     Value="Filter patterns are set — click to edit"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Members export button: teal icon button -->
        <Style x:Key="MembersBtnStyle" TargetType="Button">
            <Setter Property="Width"             Value="26"/>
            <Setter Property="Height"            Value="22"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="Foreground"        Value="{DynamicResource MahApps.Brushes.Gray3}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="BorderBrush"       Value="{DynamicResource MahApps.Brushes.Gray7}"/>
            <Setter Property="ToolTip"           Value="Export members / contacts"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#00796B"/>
                    <Setter Property="Foreground"  Value="White"/>
                    <Setter Property="BorderBrush" Value="#004D40"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Compact pill / toggle-button for the Providers column -->
        <Style x:Key="ProviderPillStyle" TargetType="ToggleButton">
            <Setter Property="Padding"          Value="5,2"/>
            <Setter Property="Margin"           Value="2,0"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="MinWidth"         Value="28"/>
            <Setter Property="Height"           Value="20"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderBrush"      Value="#BBBBBB"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Foreground"       Value="#888888"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background"  Value="#2196F3"/>
                    <Setter Property="Foreground"  Value="White"/>
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for the Folder button: blue when a custom template is set, plain otherwise -->
        <Style x:Key="FolderBtnStyle" TargetType="Button">
            <Setter Property="Width"  Value="26"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray3}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray7}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding FolderTemplate, Converter={StaticResource StringNotEmpty}}"
                             Value="True">
                    <Setter Property="Background"   Value="#2196F3"/>
                    <Setter Property="Foreground"   Value="White"/>
                    <Setter Property="BorderBrush"  Value="#1565C0"/>
                    <Setter Property="FontWeight"   Value="Bold"/>
                    <Setter Property="ToolTip"      Value="Custom folder is set — click to edit"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row: search + stats + chat count -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,6">
            <StackPanel>
                <DockPanel Margin="0,0,0,4">
                    <TextBox x:Name="SearchTextBox" DockPanel.Dock="Left" Width="280"
                             mah:TextBoxHelper.Watermark="Search chats..."
                             mah:TextBoxHelper.ClearTextButton="True"
                             TextChanged="SearchTextBox_TextChanged"
                             VerticalContentAlignment="Center" Height="32"
                             Margin="0,0,12,0"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button x:Name="BtnRefreshChats" Content="🔄 Refresh" Height="28"
                                Click="BtnRefreshChats_Click" Margin="0,0,8,0"
                                ToolTip="Reload chat list from Telegram"/>
                        <Button x:Name="BtnSettings" Content="⚙ Settings" Height="28"
                                Click="BtnSettings_Click" Margin="0,0,12,0"/>
                        <TextBlock Text="Chats:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#666"/>
                        <Border Background="#2AABEE" CornerRadius="10" Padding="8,2">
                            <TextBlock x:Name="tbCountChats" Text="0" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </DockPanel>
                <!-- Session statistics strip -->
                <Border Background="#E3F2FD" CornerRadius="4" Padding="10,3" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊 This session: " Foreground="#1565C0" FontSize="11"/>
                        <TextBlock x:Name="tbStatsFiles" Text="0 files" FontWeight="SemiBold" Foreground="#1565C0" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock Text="|" Foreground="#90CAF9" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock x:Name="tbStatsBytes" Text="0 B" FontWeight="SemiBold" Foreground="#1565C0" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock Text="|" Foreground="#90CAF9" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock x:Name="tbStatsActive" Text="0 active" Foreground="#1565C0" FontSize="11" Margin="0,0,20,0"/>
                        <TextBlock Text="🗄 All-time: " Foreground="#555" FontSize="11"/>
                        <TextBlock x:Name="tbAllTimeFiles" Text="0 files" FontWeight="SemiBold" Foreground="#555" FontSize="11" Margin="0,0,8,0"/>
                        <TextBlock Text="|" Foreground="#BDBDBD" FontSize="11" Margin="0,0,8,0"/>
                        <TextBlock x:Name="tbAllTimeBytes" Text="0 B" FontWeight="SemiBold" Foreground="#555" FontSize="11"/>
                    </StackPanel>
                </Border>
                <!-- Disk space strip -->
                <Border x:Name="diskSpaceStrip" Background="#E8F5E9" CornerRadius="4" Padding="10,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾 Drive: " Foreground="#2E7D32" FontSize="11"/>
                        <TextBlock x:Name="tbDiskInfo" Text="—" FontWeight="SemiBold" Foreground="#2E7D32" FontSize="11" Margin="0,0,16,0"/>
                        <TextBlock Text="|" Foreground="#A5D6A7" FontSize="11" Margin="0,0,16,0"/>
                        <TextBlock Text="📂 Download folder: " Foreground="#33691E" FontSize="11"/>
                        <TextBlock x:Name="tbFolderDiskInfo" Text="—" FontWeight="SemiBold" Foreground="#33691E" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main content with GridSplitter -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <!-- Top panel: chat list (70%) -->
                <RowDefinition Height="7*"/>
                <RowDefinition Height="4"/>
                <!-- Bottom panel: active downloads (30%) -->
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <!-- Chat ListView -->
            <ListView x:Name="ItemsListView" Grid.Row="0" SelectionMode="Extended" Margin="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.IsDeferredScrollingEnabled="False"
                      GridViewColumnHeader.Click="ColumnHeader_Click">
                <ListView.Resources>
                    <Style TargetType="GridViewColumnHeader">
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="ToolTip" Value="Click to sort"/>
                    </Style>
                    <!-- Alternating row colors -->
                    <Style TargetType="ListViewItem">
                        <EventSetter Event="MouseDoubleClick" Handler="ChatList_Item_MouseDoubleClick"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#F9F9F9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F4FD"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Resources>
                <ListView.AlternationCount>2</ListView.AlternationCount>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="" Width="44">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Unchecked="SelectChatId_Checked" Checked="SelectChatId_Checked" 
                                              IsChecked="{Binding Selected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="ID" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Id}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Name" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Username" Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Username}" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Type" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="6,2" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#607D8B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Channel">
                                                        <Setter Property="Background" Value="#2196F3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="Group">
                                                        <Setter Property="Background" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="User">
                                                        <Setter Property="Background" Value="#9C27B0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Type}" Foreground="White" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <!-- Member count column -->
                        <GridViewColumn Header="Members" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MembersCount, StringFormat={}{0:N0}}"
                                               VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Start Icon" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Tag="start"
                                              Loaded="DownloadStartIcon_Loaded"
                                              DropDownOpened="EmojiComboBox_DropDownOpened"
                                              SelectionChanged="DownloadStartIcon_SelectionChanged" Width="70"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="End Icon" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Tag="end"
                                              Loaded="EndIconComboBox_Loaded"
                                              DropDownOpened="EmojiComboBox_DropDownOpened"
                                              SelectionChanged="ComboBox_SelectionChanged" Width="60"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Download Types" Width="280">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox Content="Videos" IsChecked="{Binding Download.Videos, Mode=TwoWay}" Checked="Download_Checked" Unchecked="Download_Checked" Loaded="Download_Loaded" Margin="6,0"/>
                                        <CheckBox Content="Photos" IsChecked="{Binding Download.Photos, Mode=TwoWay}" Checked="Download_Checked" Unchecked="Download_Checked" Loaded="Download_Loaded" Margin="6,0"/>
                                        <CheckBox Content="Music" IsChecked="{Binding Download.Music, Mode=TwoWay}" Checked="Download_Checked" Unchecked="Download_Checked" Loaded="Download_Loaded" Margin="6,0"/>
                                        <CheckBox Content="Files" IsChecked="{Binding Download.Files, Mode=TwoWay}" Checked="Download_Checked" Unchecked="Download_Checked" Loaded="Download_Loaded" Margin="6,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <!-- Renamed from "Min Size (MB)" for clarity -->
                        <GridViewColumn Header="Min Size Download (MB)" Width="145">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding DownloadFromSize, Mode=TwoWay}" 
                                             TextChanged="DownloadSize_TextChanged" 
                                             Width="80" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Providers: SO covers YouTube/social. TR=Torrent. DL=direct URL ("Other" plugin). -->
                        <GridViewColumn Header="Providers" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- SO covers YouTube/TikTok/Facebook/X/etc via yt-dlp (Priority 2).
                                         YT pill removed — SO handles YouTube already.
                                         DL tag fixed to "Other" (DownladerPlugin.PluginName). -->
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton Content="SO"  Tag="SocialMedia"
                                                      Style="{StaticResource ProviderPillStyle}"
                                                      Loaded="ProviderPill_Loaded" Click="ProviderPill_Click"
                                                      ToolTip="Social Media (YouTube, TikTok, Facebook, X, …)"/>
                                        <ToggleButton Content="TR"  Tag="Torrent"
                                                      Style="{StaticResource ProviderPillStyle}"
                                                      Loaded="ProviderPill_Loaded" Click="ProviderPill_Click"
                                                      ToolTip="Torrent"/>
                                        <ToggleButton Content="DL"  Tag="Other"
                                                      Style="{StaticResource ProviderPillStyle}"
                                                      Loaded="ProviderPill_Loaded" Click="ProviderPill_Click"
                                                      ToolTip="Direct URL Download"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Filter: amber when patterns set, opens full FilterDialog -->
                        <GridViewColumn Header="Filter" Width="52">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="⚡"
                                            Style="{StaticResource FilterBtnStyle}"
                                            Tag="{Binding}"
                                            Click="FilterDialog_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Folder: custom download folder template per chat -->
                        <GridViewColumn Header="Folder" Width="52">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <!-- Blue when a custom template is set, plain when using default layout -->
                                    <Button Content="…"
                                            Style="{StaticResource FolderBtnStyle}"
                                            Tag="{Binding}"
                                            Click="FolderTemplateDialog_Click"
                                            ToolTip="Open folder template editor"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Members: export group/channel members to CSV or vCard -->
                        <GridViewColumn Header="👥" Width="38">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="👥"
                                            Style="{StaticResource MembersBtnStyle}"
                                            Tag="{Binding}"
                                            Click="MembersExport_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Sync column: download all existing media files from history -->
                        <GridViewColumn Header="Sync" Width="85">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="⬇ Sync" Height="24" Padding="4,0" FontSize="11"
                                            Margin="8,0,0,0"
                                            AutomationProperties.AutomationId="ChatHistorySyncButton"
                                            ToolTip="Download all existing files from this chat's history"
                                            Tag="{Binding}"
                                            Click="BtnSyncChat_Click"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- History: save every message to a JSONL log file -->
                        <GridViewColumn Width="175">
                            <GridViewColumn.Header>
                                <TextBlock Text="History" ToolTip="Save all messages to a JSONL file in History/{Chat}.jsonl"/>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox Height="22" VerticalAlignment="Center" Margin="4,0,4,0"
                                                  ToolTip="Track new messages in a JSONL history file"
                                                  Loaded="HistoryCheckBox_Loaded"
                                                  Click="HistoryCheckBox_Click"/>
                                        <ComboBox Tag="history"
                                                  Loaded="HistoryIconComboBox_Loaded"
                                                  DropDownOpened="EmojiComboBox_DropDownOpened"
                                                  SelectionChanged="HistoryIconComboBox_SelectionChanged"
                                                  Width="60"
                                                  ToolTip="Reaction sent to Telegram when a message is saved to history (only when History is enabled)"/>
                                        <Button Content="📤" Height="22" Width="26" FontSize="11"
                                                Padding="0" VerticalAlignment="Center"
                                                Tag="{Binding}"
                                                Click="BtnExportHistory_Click"
                                                ToolTip="Export full chat history to JSONL file now"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Mute column: suppress Telegram notifications for this chat -->
                        <GridViewColumn Header="Mute" Width="65">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="btnMute"
                                            Height="24" Padding="4,0" FontSize="13"
                                            Tag="{Binding}"
                                            Click="BtnMuteChat_Click"
                                            ToolTip="Mute / unmute Telegram notifications for this chat">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Content" Value="🔔"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Muted}" Value="True">
                                                        <Setter Property="Content" Value="🔕"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- GridSplitter -->
            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" 
                          Background="#E0E0E0" ResizeBehavior="PreviousAndNext"/>

            <!-- Active Downloads panel -->
            <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <DockPanel>
                    <!-- Panel header with live download count badge -->
                    <DockPanel DockPanel.Dock="Top" Margin="12,8,12,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬇ Downloads" FontWeight="SemiBold" Foreground="#444" VerticalAlignment="Center"/>
                            <!-- Active badge -->
                            <Border x:Name="downloadCountBadge" Background="#2AABEE" CornerRadius="10" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="tbDownloadCount" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <!-- Queued badge -->
                            <Border x:Name="queueCountBadge" Background="#FF9800" CornerRadius="10" Padding="6,1" Margin="6,0,0,0" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏳ " FontSize="11" Foreground="White"/>
                                    <TextBlock x:Name="tbQueueCount" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text=" waiting" FontSize="11" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <!-- Total speed indicator -->
                            <Border x:Name="totalSpeedBadge" Background="#E3F2FD" CornerRadius="6" Padding="8,1" Margin="10,0,0,0" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡ " FontSize="11" Foreground="#1565C0"/>
                                    <TextBlock x:Name="tbTotalSpeed" Text="" FontSize="11" FontWeight="SemiBold" Foreground="#1565C0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <!-- Auto clean + Cancel All — right-aligned in the header bar -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="chkAutoCleanDownloads" Content="Auto clean"
                                      IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"
                                      ToolTip="Remove completed downloads from the list after a few seconds"
                                      Checked="AutoCleanDownloads_Changed" Unchecked="AutoCleanDownloads_Changed"/>
                            <Button x:Name="btnCancelAll" Content="✕ Cancel All"
                                    Height="22" Padding="8,0" FontSize="11"
                                    Foreground="#F44336" Background="Transparent"
                                    BorderBrush="#F44336" BorderThickness="1"
                                    Cursor="Hand" ToolTip="Cancel all active downloads"
                                    Click="CancelAllDownloads_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="dgDownloads" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              RowHeaderWidth="0" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent" Margin="4,0"
                              FontSize="12">
                        <DataGrid.Columns>
                            <!-- File name — capped star width to avoid excessive empty space -->
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*" MinWidth="120"/>

                            <!-- Chat name -->
                            <DataGridTextColumn Header="Chat" Binding="{Binding ChatName}" Width="110"/>

                            <!-- Plugin -->
                            <DataGridTextColumn Header="Plugin" Binding="{Binding PluginName}" Width="80"/>

                            <!-- Size: downloaded / total -->
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="130"/>

                            <!-- Progress bar + % text -->
                            <DataGridTemplateColumn Header="Progress" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2">
                                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="16"/>
                                            <TextBlock Text="{Binding ProgressText}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Download speed -->
                            <DataGridTextColumn Header="Speed" Binding="{Binding Speed}" Width="90"/>

                            <!-- ETA -->
                            <DataGridTextColumn Header="ETA" Binding="{Binding Eta}" Width="75"/>

                            <!-- Status — red on error with tooltip showing the error message -->
                            <DataGridTemplateColumn Header="Status" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#333"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="✔ Done">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="✖ Error">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="✖ Cancelled">
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                                            <Setter Property="ToolTip" Value="{Binding ErrorMessage}"/>
                                                            <Setter Property="TextDecorations" Value="Underline"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Open file/folder — visible when download finished and path is known -->
                            <DataGridTemplateColumn Header="" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="📂" Width="34" Height="22" FontSize="13"
                                                Tag="{Binding}"
                                                Click="OpenDownload_Click"
                                                Foreground="#4CAF50" Background="Transparent"
                                                BorderBrush="#4CAF50" BorderThickness="1"
                                                Cursor="Hand" ToolTip="Open downloaded file">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanOpenFile}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Retry button — visible only when CanRetry is true -->
                            <DataGridTemplateColumn Header="" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="↺" Width="34" Height="22" FontSize="13"
                                                Tag="{Binding}"
                                                Click="RetryDownload_Click"
                                                Foreground="#2196F3" Background="Transparent"
                                                BorderBrush="#2196F3" BorderThickness="1"
                                                Cursor="Hand" ToolTip="Retry failed download">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanRetry}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Cancel button -->
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="36" Height="22" FontSize="11"
                                                Tag="{Binding}"
                                                Click="CancelDownload_Click"
                                                Foreground="#F44336" Background="Transparent"
                                                BorderBrush="#F44336" BorderThickness="1"
                                                Cursor="Hand" ToolTip="Cancel download">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="✔ Done">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="✖ Error">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="✖ Cancelled">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Footer / Status bar -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel>
                <!-- Right: version + connection dot + path controls -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnErrorLog"
                            Visibility="Collapsed"
                            Height="22" Padding="8,0" Margin="0,0,10,0"
                            Background="#D32F2F" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            VerticalAlignment="Center"
                            ToolTip="Error(s) detected — click to view logs"
                            Click="BtnErrorLog_Click">
                        <TextBlock Text="⚠ Errors" FontWeight="SemiBold" FontSize="11"/>
                    </Button>
                    <Button x:Name="btnAppVersion" Content="v2.8.0"
                            Style="{x:Null}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#999" Cursor="Hand" Padding="4,0"
                            VerticalAlignment="Center" Margin="0,0,12,0"
                            ToolTip="Click to check for updates"
                            Click="BtnAppVersion_Click"/>
                    <Ellipse x:Name="connectionDot" Width="10" Height="10" Fill="Green" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <!-- Folder path — click to open in Explorer -->
                    <Button x:Name="btnOpenFolder" Click="HlOpenFolder_Click"
                            IsEnabled="False" Height="26" Padding="8,0" Margin="0,0,4,0"
                            ToolTip="Click to open download folder">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbFolderPath" Text="No folder selected"
                                       VerticalAlignment="Center" Foreground="#444"
                                       MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSelectPath" Content="📁 Select Path"
                            Click="BtnSelectPath_Click" Height="26" Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Left: loading ring + status text -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <mah:ProgressRing x:Name="mainLoadingRing" IsActive="False"
                                      Width="20" Height="20" Margin="0,0,8,0"/>
                    <TextBlock x:Name="tbLoadingStatus" Text="" VerticalAlignment="Center"
                               Foreground="#666"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</mah:MetroWindow>
