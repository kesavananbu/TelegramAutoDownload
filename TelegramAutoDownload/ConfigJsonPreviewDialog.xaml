<mah:MetroWindow x:Class="TelegramAutoDownload.ConfigJsonPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Export — preview JSON"
        Height="520" Width="640"
        MinHeight="360" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#B71C1C" FontWeight="SemiBold" Margin="0,0,0,8">
            This JSON contains secrets (API Hash, Bot Token, etc.). Store it only in a safe place.
        </TextBlock>
        <TextBlock Grid.Row="1" Text="Review the full configuration below, then copy or save to a file."
                   Foreground="#555" Margin="0,0,0,8"/>

        <TextBox Grid.Row="2" x:Name="tbJson" IsReadOnly="True" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="11" TextWrapping="No"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Copy" Width="88" Height="32" Margin="0,0,8,0" Click="BtnCopy_Click"/>
            <Button Content="Save as…" Width="96" Height="32" Margin="0,0,8,0" Click="BtnSaveAs_Click"/>
            <Button Content="Close" Width="80" Height="32" IsCancel="True" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
