<mah:MetroWindow x:Class="TelegramAutoDownload.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Update Available"
        Height="500" Width="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowMinButton="False" ShowMaxRestoreButton="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🚀" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="A new version is available!" FontSize="16" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Border Background="#E0E0E0" CornerRadius="8" Padding="8,2" Margin="0,0,8,0">
                        <TextBlock x:Name="tbCurrentVersion" Text="Current: v0.0.0" FontSize="11" Foreground="#555"/>
                    </Border>
                    <TextBlock Text="→" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#888"/>
                    <Border Background="#4CAF50" CornerRadius="8" Padding="8,2">
                        <TextBlock x:Name="tbNewVersion" Text="New: v0.0.0" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Separator -->
        <Separator Grid.Row="1" Margin="0,0,0,12"/>

        <!-- Changelog -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="What's new:" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                    <TextBlock x:Name="tbChangelog" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="12" Foreground="#333"
                               LineHeight="20"/>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- Progress bar (hidden until download starts) -->
        <Grid Grid.Row="3" Margin="0,12,0,0" x:Name="pnlProgress" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="tbProgressLabel" Text="Downloading…" FontSize="11" Margin="0,0,0,4"/>
            <ProgressBar Grid.Row="1" x:Name="progressBar" Height="10" Minimum="0" Maximum="100"/>
        </Grid>

        <!-- Buttons -->
        <DockPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock DockPanel.Dock="Left" x:Name="tbSkipInfo"
                       Text="You can update later from Help → Check for Updates."
                       FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnSkip" Content="Skip" Width="80" Height="32" Margin="0,0,8,0"
                        Click="BtnSkip_Click"/>
                <Button x:Name="btnInstall" Content="Install Now" Width="110" Height="32"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                        Click="BtnInstall_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
