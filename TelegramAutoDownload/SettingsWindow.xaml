<mah:MetroWindow x:Class="TelegramAutoDownload.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings"
        Height="700" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Telegram API section -->
                <TextBlock Text="Telegram API" FontSize="15" FontWeight="SemiBold"
                           Foreground="#2196F3" Margin="0,0,0,8"/>
                <Border Background="#F5F5F5" CornerRadius="6" Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="You can get these values at https://my.telegram.org"
                                   Foreground="#888" FontSize="11" Margin="0,0,0,12"/>

                        <TextBlock Text="App ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtAppId"
                                 mah:TextBoxHelper.Watermark="e.g. 12345678"
                                 Height="32" Margin="0,0,0,12"/>

                        <TextBlock Text="API Hash" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="pbApiHash"
                                     mah:TextBoxHelper.Watermark="32-character hex string"
                                     Height="32" Margin="0,0,0,4"/>
                        <TextBlock Text="⚠ Changing API credentials requires re-login."
                                   Foreground="#E65100" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Notification Bot section -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Notification Bot" FontSize="15" FontWeight="SemiBold"
                               Foreground="#2196F3" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <ToggleButton x:Name="toggleNotifications" HorizontalAlignment="Right"
                                  Style="{DynamicResource MahApps.Styles.ToggleButton.Switch}"
                                  Checked="ToggleNotifications_Changed" Unchecked="ToggleNotifications_Changed"/>
                </DockPanel>
                <Border Background="#FFF8E1" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                        BorderBrush="#FFE082" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ℹ" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#F9A825"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#5D4037" FontSize="11">
                            <Run FontWeight="SemiBold">Optional.</Run>
                            <Run>The app works without a bot — files are downloaded automatically in the background.
Enable this only if you want to receive a Telegram message when a download finishes (e.g. on mobile).</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="#F5F5F5" CornerRadius="6" Padding="16,12" Margin="0,0,0,20"
                        x:Name="pnlNotifications">
                    <StackPanel>
                        <TextBlock Text="Create a bot via @BotFather to receive download notifications."
                                   Foreground="#888" FontSize="11" Margin="0,0,0,12"/>

                        <TextBlock Text="Bot Token" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="pbBotToken"
                                     mah:TextBoxHelper.Watermark="123456:ABC-DEF..."
                                     Height="32" Margin="0,0,0,12"/>

                        <TextBlock Text="Chat ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtChatId"
                                 mah:TextBoxHelper.Watermark="e.g. -1001234567890"
                                 Height="32" Margin="0,0,0,16"/>

                        <!-- Notification events -->
                        <TextBlock Text="Notify me when…" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="#555"/>
                        <Border Background="#FFFDE7" CornerRadius="4" Padding="12,10"
                                BorderBrush="#FFE082" BorderThickness="1">
                            <StackPanel>
                                <CheckBox x:Name="chkNotifyStartup" Margin="0,0,0,8"
                                          IsChecked="True">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🟢 " FontSize="13"/>
                                        <StackPanel>
                                            <TextBlock Text="App starts / stops" FontWeight="SemiBold"/>
                                            <TextBlock Text="One-time message on startup with connection status."
                                                       Foreground="#888" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="chkNotifyProgress" Margin="0,0,0,8"
                                          IsChecked="True">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⬇️ " FontSize="13"/>
                                        <StackPanel>
                                            <TextBlock Text="Download progress (live)" FontWeight="SemiBold"/>
                                            <TextBlock Text="Updates the message every ~10% while downloading."
                                                       Foreground="#888" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="chkNotifyComplete" Margin="0,0,0,8"
                                          IsChecked="True">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✅ " FontSize="13"/>
                                        <StackPanel>
                                            <TextBlock Text="Download completed" FontWeight="SemiBold"/>
                                            <TextBlock Text="Message with file name and path when done."
                                                       Foreground="#888" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="chkNotifyError"
                                          IsChecked="True">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠️ " FontSize="13"/>
                                        <StackPanel>
                                            <TextBlock Text="Errors &amp; warnings" FontWeight="SemiBold"/>
                                            <TextBlock Text="Alert when a download fails or encounters an issue."
                                                       Foreground="#888" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- General section -->
                <TextBlock Text="General" FontSize="15" FontWeight="SemiBold"
                           Foreground="#2196F3" Margin="0,0,0,8"/>
                <Border Background="#F5F5F5" CornerRadius="6" Padding="16,12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Download Folder" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Browse…" Height="32" Width="72"
                                    Margin="8,0,0,0" Click="BtnBrowseFolder_Click"/>
                            <TextBox x:Name="txtDownloadPath"
                                     mah:TextBoxHelper.Watermark="Select a folder..."
                                     Height="32" IsReadOnly="True"/>
                        </DockPanel>

                        <TextBlock Text="Parallel Download Threads" FontWeight="SemiBold" Margin="0,16,0,4"/>
                        <DockPanel>
                            <TextBlock x:Name="tbThreadsValue" DockPanel.Dock="Right" Width="28"
                                       VerticalAlignment="Center" TextAlignment="Right" Text="3"/>
                            <Slider x:Name="sliderThreads" Minimum="1" Maximum="10" Value="3"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="SliderThreads_ValueChanged"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="80" Height="32" Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>
            <Button Content="Save" Width="80" Height="32" IsDefault="True"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>

</mah:MetroWindow>
